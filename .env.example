# PostgreSQL
POSTGRES_SERVER=db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=kurobara
POSTGRES_PORT=5432

# Backend
SECRET_KEY=changethiskeytosomethingsecure
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=admin

# Google OAuth (replace with real values in production)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Frontend
REACT_APP_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Rate Limiting
REDIS_URL=redis://localhost:6379/0
RATE_LIMITING_ENABLED=true

# Security Settings
TWO_FACTOR_AUTH_REQUIRED=false

# Content Settings
DEFAULT_BLUR_NSFW=true
DEFAULT_SHOW_EXPLICIT_ON_DASHBOARD=false

# Email Settings
SMTP_TLS=true
SMTP_PORT=587
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=info@example.com
EMAILS_FROM_NAME=Kurobara
EMAIL_RESET_TOKEN_EXPIRE_HOURS=48
EMAILS_ENABLED=false

# API Settings
SERVER_NAME=kurobara
SERVER_HOST=http://localhost
PROJECT_NAME=Kurobara
ACCESS_TOKEN_EXPIRE_MINUTES=11520
